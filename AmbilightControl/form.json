{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "WLED connection",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "WLEDHost",
          "caption": "Host or IP address"
        },
        {
          "type": "NumberSpinner",
          "name": "WLEDPort",
          "caption": "Port",
          "minimum": 1,
          "maximum": 65535
        },
        {
          "type": "CheckBox",
          "name": "WLEDHTTPS",
          "caption": "Use HTTPS"
        },
        {
          "type": "NumberSpinner",
          "name": "WarmWhitePreset",
          "caption": "Warm-white preset",
          "minimum": 0,
          "maximum": 250
        },
        {
          "type": "NumberSpinner",
          "name": "NightPreset",
          "caption": "Night preset",
          "minimum": 0,
          "maximum": 250
        },
        {
          "type": "NumberSpinner",
          "name": "CleaningPreset",
          "caption": "Cleaning preset",
          "minimum": 0,
          "maximum": 250
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "HyperHDR connection",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "HyperHDRHost",
          "caption": "Host or IP address"
        },
        {
          "type": "NumberSpinner",
          "name": "HyperHDRPort",
          "caption": "Port",
          "minimum": 1,
          "maximum": 65535
        },
        {
          "type": "CheckBox",
          "name": "HyperHDRHTTPS",
          "caption": "Use HTTPS"
        },
        {
          "type": "PasswordTextBox",
          "name": "HyperHDRToken",
          "caption": "Authorization token"
        },
        {
          "type": "NumberSpinner",
          "name": "HyperHDRInstance",
          "caption": "HyperHDR instance",
          "minimum": 0,
          "maximum": 255
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Apple TV monitor",
      "items": [
        {
          "type": "CheckBox",
          "name": "AppleTVEnabled",
          "caption": "Enable Apple TV monitoring"
        },
        {
          "type": "ValidationTextBox",
          "name": "AppleTVMonitorHost",
          "caption": "Raspberry Pi host or IP address"
        },
        {
          "type": "NumberSpinner",
          "name": "AppleTVMonitorPort",
          "caption": "Monitor port",
          "minimum": 1,
          "maximum": 65535
        },
        {
          "type": "CheckBox",
          "name": "AppleTVMonitorHTTPS",
          "caption": "Use HTTPS"
        },
        {
          "type": "ValidationTextBox",
          "name": "AppleTVMonitorPath",
          "caption": "Status path"
        },
        {
          "type": "NumberSpinner",
          "name": "AppleTVPollInterval",
          "caption": "Apple TV polling interval in seconds",
          "minimum": 1,
          "maximum": 60
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Automation",
      "items": [
        {
          "type": "CheckBox",
          "name": "AutomationEnabled",
          "caption": "Enable automation after applying changes"
        },
        {
          "type": "SelectVariable",
          "name": "SourceVariableID",
          "caption": "Media-state variable"
        },
        {
          "type": "ValidationTextBox",
          "name": "PlayingValues",
          "caption": "Values for live mode (comma-separated)"
        },
        {
          "type": "ValidationTextBox",
          "name": "PausedValues",
          "caption": "Values for pause mode (comma-separated)"
        },
        {
          "type": "ValidationTextBox",
          "name": "OffValues",
          "caption": "Values for off mode (comma-separated)"
        },
        {
          "type": "Select",
          "name": "PausedMode",
          "caption": "Mode while paused",
          "options": [
            {
              "caption": "Off",
              "value": 0
            },
            {
              "caption": "Live",
              "value": 1
            },
            {
              "caption": "Warm white",
              "value": 2
            },
            {
              "caption": "Night",
              "value": 3
            },
            {
              "caption": "Cleaning",
              "value": 4
            }
          ]
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "General settings",
      "items": [
        {
          "type": "NumberSpinner",
          "name": "UpdateInterval",
          "caption": "Update interval in seconds",
          "minimum": 0,
          "maximum": 86400
        },
        {
          "type": "CheckBox",
          "name": "EnableDebug",
          "caption": "Extended debug output"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Test WLED",
      "onClick": "AMBCTRL_TestWLED($id);"
    },
    {
      "type": "Button",
      "caption": "Test HyperHDR",
      "onClick": "AMBCTRL_TestHyperHDR($id);"
    },
    {
      "type": "Button",
      "caption": "Test Apple TV",
      "onClick": "AMBCTRL_TestAppleTV($id);"
    },
    {
      "type": "Button",
      "caption": "Refresh status",
      "onClick": "AMBCTRL_Update($id);"
    }
  ],
  "status": [
    {
      "code": 102,
      "icon": "active",
      "caption": "Active"
    },
    {
      "code": 104,
      "icon": "inactive",
      "caption": "Inactive"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "No WLED or HyperHDR host configured"
    },
    {
      "code": 202,
      "icon": "error",
      "caption": "WLED is not reachable"
    },
    {
      "code": 203,
      "icon": "error",
      "caption": "HyperHDR is not reachable"
    },
    {
      "code": 204,
      "icon": "error",
      "caption": "Invalid device response"
    },
    {
      "code": 205,
      "icon": "error",
      "caption": "Apple TV monitor is not reachable"
    }
  ]
}
