{
    "elements": [
        {
            "type": "ExpansionPanel",
            "caption": "Allgemein",
            "expanded": true,
            "items": [
                {
                    "type": "CheckBox",
                    "name": "Active",
                    "caption": "Modul aktiv"
                },
                {
                    "type": "NumberSpinner",
                    "name": "UpdateInterval",
                    "caption": "Aktualisierungsintervall",
                    "suffix": " Sekunden",
                    "minimum": 1,
                    "maximum": 3600
                },
                {
                    "type": "CheckBox",
                    "name": "DebugEnabled",
                    "caption": "Erweiterte Debug-Ausgabe"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "HyperHDR",
            "expanded": true,
            "items": [
                {
                    "type": "CheckBox",
                    "name": "HyperHDREnabled",
                    "caption": "HyperHDR überwachen"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "HyperHDRHost",
                    "caption": "Hostname oder IP-Adresse"
                },
                {
                    "type": "NumberSpinner",
                    "name": "HyperHDRPort",
                    "caption": "Webserver-Port",
                    "minimum": 1,
                    "maximum": 65535
                },
                {
                    "type": "CheckBox",
                    "name": "HyperHDRHTTPS",
                    "caption": "HTTPS verwenden"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "HyperHDRPath",
                    "caption": "API-Pfad"
                },
                {
                    "type": "PasswordTextBox",
                    "name": "HyperHDRToken",
                    "caption": "API-Token"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "WLED / GL-C-618WL",
            "expanded": true,
            "items": [
                {
                    "type": "CheckBox",
                    "name": "WLEDEnabled",
                    "caption": "WLED überwachen und steuern"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "WLEDHost",
                    "caption": "Hostname oder IP-Adresse"
                },
                {
                    "type": "CheckBox",
                    "name": "WLEDHTTPS",
                    "caption": "HTTPS verwenden"
                },
                {
                    "type": "Label",
                    "caption": "Bus 1 ist für HyperHDR reserviert. Die Busse 2 bis 4 werden als getrennte WLED-Segmente gesteuert."
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Apple TV",
            "expanded": true,
            "items": [
                {
                    "type": "CheckBox",
                    "name": "AppleTVEnabled",
                    "caption": "Apple-TV-Bridge überwachen"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "AppleTVHost",
                    "caption": "Bridge-Hostname oder IP-Adresse"
                },
                {
                    "type": "NumberSpinner",
                    "name": "AppleTVPort",
                    "caption": "Bridge-Port",
                    "minimum": 1,
                    "maximum": 65535
                },
                {
                    "type": "Label",
                    "caption": "Ereignisse empfängt das Modul per WebHook unter /hook/medialight. In der config.json der Bridge muss dafür webhook_url auf http://<IP-Symcon-IP>:3777/hook/medialight zeigen."
                },
                {
                    "type": "Label",
                    "caption": "Die Automatik (Variable Apple-TV-Automatik) wendet die App-Regeln unten an. Ohne Regeln gilt: playing → Live, paused → Warmweiß, standby → Aus. Bei Bridge-Ausfall wird der letzte Modus gehalten."
                },
                {
                    "type": "List",
                    "name": "AppleTVAppRules",
                    "caption": "App-Regeln",
                    "rowCount": 6,
                    "add": true,
                    "delete": true,
                    "columns": [
                        {
                            "caption": "App-ID (leer = Standardregel)",
                            "name": "AppId",
                            "width": "300px",
                            "add": "",
                            "edit": {
                                "type": "ValidationTextBox"
                            }
                        },
                        {
                            "caption": "Bei Wiedergabe",
                            "name": "PlayingMode",
                            "width": "170px",
                            "add": 1,
                            "edit": {
                                "type": "Select",
                                "options": [
                                    {
                                        "caption": "keine Änderung",
                                        "value": -1
                                    },
                                    {
                                        "caption": "Aus",
                                        "value": 0
                                    },
                                    {
                                        "caption": "Live",
                                        "value": 1
                                    },
                                    {
                                        "caption": "Warmweiß",
                                        "value": 2
                                    },
                                    {
                                        "caption": "Nacht",
                                        "value": 3
                                    },
                                    {
                                        "caption": "Kaminfeuer",
                                        "value": 5
                                    },
                                    {
                                        "caption": "Regenbogen",
                                        "value": 6
                                    }
                                ]
                            }
                        },
                        {
                            "caption": "Bei Pause",
                            "name": "PausedMode",
                            "width": "170px",
                            "add": 2,
                            "edit": {
                                "type": "Select",
                                "options": [
                                    {
                                        "caption": "keine Änderung",
                                        "value": -1
                                    },
                                    {
                                        "caption": "Aus",
                                        "value": 0
                                    },
                                    {
                                        "caption": "Live",
                                        "value": 1
                                    },
                                    {
                                        "caption": "Warmweiß",
                                        "value": 2
                                    },
                                    {
                                        "caption": "Nacht",
                                        "value": 3
                                    },
                                    {
                                        "caption": "Kaminfeuer",
                                        "value": 5
                                    },
                                    {
                                        "caption": "Regenbogen",
                                        "value": 6
                                    }
                                ]
                            }
                        },
                        {
                            "caption": "Busse 2–4",
                            "name": "BusScene",
                            "width": "180px",
                            "add": 0,
                            "edit": {
                                "type": "Select",
                                "options": [
                                    {
                                        "caption": "unverändert",
                                        "value": 0
                                    },
                                    {
                                        "caption": "aus",
                                        "value": 1
                                    },
                                    {
                                        "caption": "warmweiß gedimmt",
                                        "value": 2
                                    },
                                    {
                                        "caption": "neutralweiß",
                                        "value": 3
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "type": "Select",
                    "name": "AppleTVStandbyBusScene",
                    "caption": "Bus-Szene bei Standby (TV aus)",
                    "options": [
                        {
                            "caption": "unverändert",
                            "value": 0
                        },
                        {
                            "caption": "aus",
                            "value": 1
                        },
                        {
                            "caption": "warmweiß gedimmt",
                            "value": 2
                        },
                        {
                            "caption": "neutralweiß",
                            "value": 3
                        }
                    ]
                },
                {
                    "type": "Label",
                    "caption": "Die App-ID der gerade laufenden App zeigt die Statusvariable Apple TV App bzw. der /status-Endpunkt der Bridge (Feld app_id)."
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Core testen",
            "onClick": "AMBI_TestCore($id);"
        },
        {
            "type": "Button",
            "caption": "HyperHDR testen",
            "onClick": "AMBI_TestHyperHDR($id);"
        },
        {
            "type": "Button",
            "caption": "WLED testen",
            "onClick": "AMBI_TestWLED($id);"
        },
        {
            "type": "Button",
            "caption": "Apple TV testen",
            "onClick": "AMBI_TestAppleTV($id);"
        },
        {
            "type": "Button",
            "caption": "WLED-Segmente mit Buskonfiguration synchronisieren",
            "onClick": "AMBI_SynchronizeWLEDSegments($id);"
        },
        {
            "type": "Button",
            "caption": "Bus 2 testen",
            "onClick": "AMBI_TestWLEDBus($id, 2);"
        },
        {
            "type": "Button",
            "caption": "Bus 3 testen",
            "onClick": "AMBI_TestWLEDBus($id, 3);"
        },
        {
            "type": "Button",
            "caption": "Bus 4 testen",
            "onClick": "AMBI_TestWLEDBus($id, 4);"
        },
        {
            "type": "Button",
            "caption": "Status aktualisieren",
            "onClick": "AMBI_Update($id);"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Aktiv"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Inaktiv"
        },
        {
            "code": 201,
            "icon": "error",
            "caption": "HyperHDR nicht erreichbar"
        },
        {
            "code": 202,
            "icon": "error",
            "caption": "WLED nicht erreichbar"
        },
        {
            "code": 203,
            "icon": "error",
            "caption": "Mehrere Geräte nicht erreichbar"
        },
        {
            "code": 204,
            "icon": "error",
            "caption": "Apple-TV-Bridge nicht erreichbar"
        }
    ]
}