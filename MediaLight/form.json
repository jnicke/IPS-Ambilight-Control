{
    "elements": [
        {
            "type": "ExpansionPanel",
            "caption": "Allgemein",
            "expanded": true,
            "items": [
                {
                    "type": "CheckBox",
                    "name": "Active",
                    "caption": "Modul aktiv"
                },
                {
                    "type": "NumberSpinner",
                    "name": "UpdateInterval",
                    "caption": "Aktualisierungsintervall",
                    "suffix": " Sekunden",
                    "minimum": 1,
                    "maximum": 3600
                },
                {
                    "type": "CheckBox",
                    "name": "DebugEnabled",
                    "caption": "Erweiterte Debug-Ausgabe"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "HyperHDR",
            "expanded": true,
            "items": [
                {
                    "type": "CheckBox",
                    "name": "HyperHDREnabled",
                    "caption": "HyperHDR überwachen"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "HyperHDRHost",
                    "caption": "Hostname oder IP-Adresse"
                },
                {
                    "type": "NumberSpinner",
                    "name": "HyperHDRPort",
                    "caption": "Webserver-Port",
                    "minimum": 1,
                    "maximum": 65535
                },
                {
                    "type": "CheckBox",
                    "name": "HyperHDRHTTPS",
                    "caption": "HTTPS verwenden"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "HyperHDRPath",
                    "caption": "API-Pfad"
                },
                {
                    "type": "PasswordTextBox",
                    "name": "HyperHDRToken",
                    "caption": "API-Token"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Core testen",
            "onClick": "AMBI_TestCore($id);"
        },
        {
            "type": "Button",
            "caption": "HyperHDR testen",
            "onClick": "AMBI_TestHyperHDR($id);"
        },
        {
            "type": "Button",
            "caption": "Status aktualisieren",
            "onClick": "AMBI_Update($id);"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Aktiv"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Inaktiv"
        },
        {
            "code": 201,
            "icon": "error",
            "caption": "HyperHDR nicht erreichbar"
        }
    ]
}